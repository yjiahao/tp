@startuml
!include style.puml
skinparam arrowThickness 1.1
skinparam arrowColor LOGIC_COLOR_T4
skinparam classBackgroundColor LOGIC_COLOR

package Logic as LogicPackage {

package "Parser Classes" as ParserClasses{
}
Class XYZCommand
Class CommandResult
Class "{abstract}\nCommand" as Command


Class "<<interface>>\nLogic" as Logic
Class LogicManager
}

package AddressBookParser {
}

package Model {
}

package Storage {
}

Class HiddenOutside #FFFFFF
HiddenOutside ..> Logic

LogicManager -[hidden]right-> AddressBookParser
AddressBookParser -[hidden]right-> ParserClasses

LogicManager .right.|> Logic
LogicManager -right-> AddressBookParser
AddressBookParser -right..> ParserClasses
ParserClasses ..> XYZCommand : <<create>>
note right of ParserClasses: ParserClasses = AddCommandParser, \nEditCommandParser, etc

XYZCommand -up-|> Command
LogicManager .left.> Command : <<call>>

LogicManager -up-> Model
LogicManager -right-> Storage
Storage --[hidden] Model
Command .[hidden]up.> Storage
Command .right.> Model
note right of XYZCommand: XYZCommand = AddCommand, \nFindCommand, etc

Logic ..> CommandResult
LogicManager .down.> CommandResult
Command .up.> CommandResult : <<create>>
@enduml
